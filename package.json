{
  "name": "chatspark",
  "version": "1.0.0",
  "description": "Twitch chat & channel points → OBS particle effect overlay. Trigger visual effects from chat keywords.",
  "main": "dist/main/standalone.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc --project tsconfig.json && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 \"src/renderer/**/*.{html,css,js}\" dist/ && copyfiles -u 1 \"public/assets/**/*\" dist/",
    "dev": "npm run build && node dist/main/standalone.js",
    "bundle": "esbuild dist/main/standalone.js --bundle --platform=node --target=node18 --outfile=dist/bundle.js",
    "build:sidecar": "npm run build && npm run bundle && pkg dist/bundle.js --config package.json --targets node18-win-x64 --output src-tauri/binaries/twitch-server-x86_64-pc-windows-msvc.exe"
  },
  "keywords": [
    "twitch",
    "obs",
    "overlay"
  ],
  "author": "zoloat",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.3",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.3.5",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.4",
    "pkg": "^5.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@twurple/api": "^7.1.0",
    "@twurple/auth": "^7.1.0",
    "@twurple/eventsub-ws": "^7.1.0",
    "axios": "^1.4.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.5.0",
    "tmi.js": "^1.8.5",
    "uuid": "^9.0.0"
  },
  "pkg": {
    "assets": [
      "dist/renderer/**/*",
      "dist/assets/**/*"
    ]
  }
}
